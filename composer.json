{
    "name": "superbig/craft-vipps",
    "description": "Vipps MobilePay payment gateway for Craft Commerce",
    "type": "craft-plugin",
    "license": "proprietary",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "vipps",
        "mobilepay",
        "craft commerce",
        "commerce",
        "payment gateway"
    ],
    "support": {
        "docs": "https://github.com/superbigco/craft-vipps/blob/master/README.md",
        "issues": "https://github.com/superbigco/craft-vipps/issues"
    },
    "authors": [
        {
            "name": "Superbig",
            "homepage": "https://superbig.co"
        }
    ],
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.5",
        "craftcms/commerce": "^5.0"
    },
    "require-dev": {
        "craftcms/ecs": "dev-main",
        "craftcms/phpstan": "dev-main",
        "craftcms/rector": "dev-main",
        "markhuot/craft-pest-core": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "superbig\\vipps\\": "src/"
        }
    },
    "extra": {
        "name": "Vipps",
        "handle": "vipps",
        "hasCpSettings": false,
        "hasCpSection": false,
        "class": "superbig\\vipps\\Vipps"
    },
    "scripts": {
        "check-cs": "ecs check --ansi",
        "fix-cs": "ecs check --fix --ansi",
        "phpstan": "phpstan --memory-limit=1G",
        "test": "pest --colors=always"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2.0"
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true,
            "pestphp/pest-plugin": true
        }
    }
}
